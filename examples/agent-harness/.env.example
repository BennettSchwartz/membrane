# Copy to .env for local live LLM runs. The deterministic test does not need
# LLM credentials.

# Use one provider key. OpenRouter is the default OpenAI-compatible provider
# when OPENROUTER_API_KEY is present.
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# AGENT_HARNESS_API_KEY=

# Optional LLM overrides.
# AGENT_HARNESS_BASE_URL=https://openrouter.ai/api/v1
# AGENT_HARNESS_MODEL=openai/gpt-5.5
# OPENROUTER_MODEL=openai/gpt-5.5
# OPENAI_MODEL=gpt-5.5
# AGENT_HARNESS_MAX_TOKENS=1200
# AGENT_HARNESS_REQUEST_TIMEOUT_MS=60000
# AGENT_HARNESS_MAX_RETRIES=1

# Optional external Membrane daemon. Leave unset to auto-start a temporary
# SQLite-backed membraned instance.
# MEMBRANE_ADDR=127.0.0.1:9090
# MEMBRANE_API_KEY=

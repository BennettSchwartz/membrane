# Copy to .env and fill in values. .env is gitignored.

# Required for API-mode eval (pgvector + OpenRouter embeddings).
MEMBRANE_EMBEDDING_API_KEY=
MEMBRANE_POSTGRES_DSN=postgres://membrane:membrane@localhost:5432/membrane_test?sslmode=disable

# Optional overrides (defaults shown).
# MEMBRANE_EMBEDDING_ENDPOINT=https://openrouter.ai/api/v1/embeddings
# MEMBRANE_EMBEDDING_MODEL=openai/text-embedding-3-small
# MEMBRANE_EMBEDDING_DIMENSIONS=1536
